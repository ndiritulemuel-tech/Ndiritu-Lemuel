{
  "entities": {
    "userProfile": {
      "title": "User Profile",
      "description": "User profile with their settings.",
      "type": "object",
      "properties": {
        "email": { "type": "string" },
        "avatarUrl": { "type": "string" },
        "pseudonym": { "type": "string" },
        "supportFocus": { "type": "string" },
        "identityPref": { "type": "string" },
        "partnerContact": { "type": "string" },
        "coachColors": { "type": "string" },
        "coachVoice": { "type": "string", "enum": ["male", "female", "neutral"] },
        "createdAt": { "type": "string" },
        "updatedAt": { "type": "string" }
      },
      "required": ["email", "createdAt", "updatedAt"]
    },
    "journalEntry": {
      "title": "Journal Entry",
      "description": "User's journal or milestone entry.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "content": { "type": "string" },
        "date": { "type": "string" },
        "type": { "type": "string", "enum": ["daily", "milestone"] },
        "createdAt": { "type": "string" },
        "updatedAt": { "type": "string" }
      },
      "required": ["title", "content", "date", "type", "createdAt", "updatedAt"]
    },
    "directChat": {
      "title": "Direct Chat",
      "description": "A direct chat between two users",
      "type": "object",
      "properties": {
        "participants": { "type": "array", "items": { "type": "string" } },
        "updatedAt": { "type": "string" }
      },
      "required": ["participants", "updatedAt"]
    },
    "directMessage": {
      "title": "Direct Message",
      "description": "A message in a direct chat",
      "type": "object",
      "properties": {
        "text": { "type": "string" },
        "senderId": { "type": "string" },
        "createdAt": { "type": "string" }
      },
      "required": ["text", "senderId", "createdAt"]
    },
    "groupChat": {
      "title": "Group Chat",
      "description": "A group chat room",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "ownerId": { "type": "string" },
        "members": { "type": "array", "items": { "type": "string" } },
        "createdAt": { "type": "string" },
        "updatedAt": { "type": "string" }
      },
      "required": ["name", "ownerId", "members", "createdAt", "updatedAt"]
    },
    "chatMessage": {
      "title": "Chat Message",
      "description": "A message inside a group chat",
      "type": "object",
      "properties": {
        "text": { "type": "string" },
        "senderId": { "type": "string" },
        "senderName": { "type": "string" },
        "createdAt": { "type": "string" }
      },
      "required": ["text", "senderId", "senderName", "createdAt"]
    },
    "typingIndicator": {
      "title": "Typing Indicator",
      "description": "User's current typing status in a chat",
      "type": "object",
      "properties": {
        "isTyping": { "type": "boolean" },
        "updatedAt": { "type": "string" }
      },
      "required": ["isTyping", "updatedAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/userProfile" },
      "description": "User profile document. Tied to Firebase Auth UID."
    },
    "/users/{userId}/journals/{journalId}": {
      "schema": { "$ref": "#/entities/journalEntry" },
      "description": "User's journals and milestones."
    },
    "/users/{userId}/moods/{moodId}": {
      "schema": { "$ref": "#/entities/moodLog" },
      "description": "User's mood tracking entries."
    },
    "/directChats/{chatId}": {
      "schema": { "$ref": "#/entities/directChat" },
      "description": "Direct chat between 2 users"
    },
    "/directChats/{chatId}/messages/{messageId}": {
      "schema": { "$ref": "#/entities/directMessage" },
      "description": "Messages within a direct chat"
    },
    "/groups/{groupId}": {
      "schema": { "$ref": "#/entities/groupChat" },
      "description": "Group chat rooms"
    },
    "/groups/{groupId}/messages/{messageId}": {
      "schema": { "$ref": "#/entities/chatMessage" },
      "description": "Messages within a group chat"
    },
    "/directChats/{chatId}/typingIndicators/{userId}": {
      "schema": { "$ref": "#/entities/typingIndicator" },
      "description": "Typing indicators for direct chats"
    },
    "/groups/{groupId}/typingIndicators/{userId}": {
      "schema": { "$ref": "#/entities/typingIndicator" },
      "description": "Typing indicators for group chats"
    }
  }
}
